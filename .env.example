CLAUDE_API_KEY=sk-ant-...
# 사용할 Claude 모델 (기본값: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Paper trading (기본값: ALPACA_MODE 미설정 시)
ALPACA_API_KEY=your_paper_key
ALPACA_API_SECRET=your_paper_secret

# Live trading (ALPACA_MODE=live 로 전환 시 사용)
ALPACA_LIVE_KEY=your_live_key
ALPACA_LIVE_SECRET=your_live_secret

# paper | live  (기본값: paper)
ALPACA_MODE=paper

# finly-backend에서 이 서비스를 호출할 경우 허용 origin
ALLOWED_ORIGIN=http://localhost:8000
